<!DOCTYPE html>
<html>
<head>
    <title>Guessing Game</title>
</head>
<body>

<h1>Guessing Game</h1>

<button onclick="createSession()">
    Create Session
</button>

<button onclick="joinSession()">
    Join Session
</button>

<hr>

<pre id="output"></pre>

<script src="/socket.io/socket.io.js"></script>

<script>
const socket = io();

const output =
    document.getElementById(
        "output"
    );

socket.on(
    "connect",
    () => {
        console.log(
            socket.id
        );
    }
);

socket.on(
    "session-update",
    session => {
        output.textContent =
            JSON.stringify(
                session,
                null,
                2
            );
    }
);

function createSession() {
    const name =
        prompt(
            "Your name"
        );

    socket.emit(
        "create-session",
        name,
        response => {
            console.log(
                response
            );

            if (
                response.error
            ) {
                alert(
                    response.error
                );

                return;
            }

            alert(
                `Session ID: ${response.sessionId}`
            );
        }
    );
}

function joinSession() {
    const sessionId =
        prompt(
            "Session ID"
        );

    const name =
        prompt(
            "Your name"
        );

    socket.emit(
        "join-session",
        {
            sessionId,
            name,
        },
        response => {
            console.log(
                response
            );

            if (
                response.error
            ) {
                alert(
                    response.error
                );
            }
        }
    );
}
</script>

</body>
</html>
